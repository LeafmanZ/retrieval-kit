# retrieval-kit standalone configuration
# Copy to .env and fill in your values

# AWS authentication (pick one method)
# Method 1: Named SSO profile
# AWS_PROFILE=my-sso-profile

# Method 2: Static keys (not recommended for production)
# ACCESS_KEY=
# SECRET_ACCESS_KEY=

# Method 3: Default credential chain (env vars, ~/.aws/credentials, instance role)
# (no config needed)

# AWS region
REGION=us-gov-west-1

# Bedrock Knowledge Base
KNOWLEDGE_BASE_ID=
DATA_SOURCE_ID=
BEDROCK_MODEL_ID=amazon.nova-pro-v1:0

# Bucket name prefix (leave empty for standalone)
# Buckets: {APP_PREFIX}retrieval-kit-source-documents, {APP_PREFIX}retrieval-kit-original-documents, {APP_PREFIX}retrieval-kit-audit-logs
APP_PREFIX=

# Standalone auth — seed admin account on first run
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=changeme
# REGISTER_EMAIL=admin@example.com  # Shown on login page as contact for account requests
# SECRET_KEY=  # Flask session secret (auto-generated if omitted)
